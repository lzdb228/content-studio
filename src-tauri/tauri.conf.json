{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "内容工坊",
  "version": "1.2.0",
  "identifier": "com.xingliu.content-studio",
  "build": {
    "beforeDevCommand": "cross-env NODE_ENV=development npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cross-env NODE_ENV=development npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "内容工坊 · Content Studio",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:5504 http://127.0.0.1:5200 https://open.feishu.cn https://api.linear.app"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    },
    "category": "Productivity",
    "shortDescription": "公众号对标采集·蒸馏·二创·发布",
    "longDescription": "内容工坊是一站式桌面工具：采集对标公众号文章 → 飞书入库 → 风格蒸馏 → AI 二创 → 一键发布到微信草稿箱。"
  }
}
